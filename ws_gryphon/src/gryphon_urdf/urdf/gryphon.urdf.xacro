<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="gryphon_arm">

    <!-- Load Simulated or Real Hardware Interfaces -->
    <xacro:arg name="is_sim" default="true"/>

    <!-- Include Gazebo Parameters -->
    <xacro:include filename="$(find gryphon_urdf)/urdf/gryphon_gazebo.xacro" />

    <!-- Include ros2_control Plugins -->
    <xacro:include filename="$(find gryphon_urdf)/urdf/gryphon_arm.ros2_control.xacro" />

    <!-- Useful XACRO Variables (Properties) -->
    <xacro:property name="PI" value="3.14159265359" />
    <xacro:property name="effort" value="4.0" />
    <xacro:property name="velocity" value="1.0" />

    <!-- Useful Macros -->
    <xacro:macro name="default_inertial" params="mass">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${mass}" />
            <inertia ixx="1.0" ixy="0.0" ixz="0.0"
                     iyy="1.0" iyz="0.0"
                     izz="1.0" />
        </inertial>
    </xacro:macro>

    <!-- Material definitions -->
    <material name="silver">
        <color rgba="0.700 0.700 0.700 1.0"/>
    </material>


    <!-- Links -->
    <link name="world"/>

    <link name="base_link">
        <inertial>
            <origin xyz="2.6075162618733064e-09 -0.029687845824987256 0.05035622678340518" rpy="0 0 0"/>
            <mass value="8.760837729915295"/>
            <inertia ixx="0.055534" iyy="0.036307" izz="0.037464" ixy="0.0" iyz="-0.011146" ixz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="link_1">
        <inertial>
            <origin xyz="-0.0002522803737960238 -0.06081817480908806 0.07933683412425585" rpy="0 0 0"/>
            <mass value="36.4482470253964"/>
            <inertia ixx="0.220238" iyy="0.141934" izz="0.195048" ixy="0.000816" iyz="-0.010654" ixz="0.00101"/>
        </inertial>
        <visual>
            <origin xyz="0.0 -0.0 -0.19" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Waist_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.0 -0.0 -0.19" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Waist_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="link_2">
        <inertial>
            <origin xyz="-0.05556645527562071 -0.004167729265803565 3.3002623928135577e-07" rpy="0 0 0"/>
            <mass value="62.39457105281159"/>
            <inertia ixx="1.477617" iyy="0.174618" izz="1.429036" ixy="0.016793" iyz="0.0" ixz="-0.0"/>
        </inertial>
        <visual>
            <origin xyz="0.07 -0.026322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Shoulder_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.07 -0.026322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Shoulder_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="link_3">
        <inertial>
            <origin xyz="0.052001488366736424 0.015387963557426054 2.295063472990133e-06" rpy="0 0 0"/>
            <mass value="26.84125839669147"/>
            <inertia ixx="0.324303" iyy="0.046323" izz="0.326785" ixy="1e-06" iyz="-1.1e-05" ixz="-0.0"/>
        </inertial>
        <visual>
            <origin xyz="0.07 -0.251322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Elbow_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.07 -0.251322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Elbow_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="link_4">
        <inertial>
            <origin xyz="-0.028000182710083837 0.0023134756758433905 -2.0573877996199474e-05" rpy="0 0 0"/>
            <mass value="0.07336127644204224"/>
            <inertia ixx="4e-06" iyy="1.4e-05" izz="1.6e-05" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
        </inertial>
        <visual>
            <origin xyz="-0.01 -0.476322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_T_shape_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="-0.01 -0.476322 -0.376322" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_T_shape_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="link_5">
        <inertial>
            <origin xyz="-1.9698045254992747e-07 0.04756806709239264 2.6795981544758263e-08" rpy="0 0 0"/>
            <mass value="0.6360331426782216"/>
            <inertia ixx="0.000418" iyy="0.00015" izz="0.000404" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
        </inertial>
        <visual>
            <origin xyz="0.018 -0.498134 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_gripper_base_v2_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.018 -0.498134 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_gripper_base_v2_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="gripper_mid_point">
        <xacro:default_inertial mass="0.01"/>
    </link>

    <link name="gripper_finger_right">
        <inertial>
            <origin xyz="0.005010907689285325 0.007530308144696352 3.1698777935851297e-08" rpy="0 0 0"/>
            <mass value="0.04489078009580989"/>
            <inertia ixx="1e-05" iyy="3e-06" izz="1.1e-05" ixy="-3e-06" iyz="-0.0" ixz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0.008258 -0.579592 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_r_gripper_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.008258 -0.579592 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_r_gripper_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>

    <link name="gripper_finger_left">
        <inertial>
            <origin xyz="-0.005009888223430386 0.0075296833236281335 5.85669156838442e-07" rpy="0 0 0"/>
            <mass value="0.04488910182418366"/>
            <inertia ixx="1e-05" iyy="3e-06" izz="1.1e-05" ixy="3e-06" iyz="-0.0" ixz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0.027743 -0.579592 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_l_gripper_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0.027743 -0.579592 -0.376318" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://gryphon_urdf/meshes/Wrist_l_gripper_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
    </link>


    <!-- Joints -->
    <joint name="virtual_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0.0 0.0 0.19" rpy="0 0 0"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="1.0"/>
    </joint>

    <joint name="joint_2" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="-0.07 0.026322 0.186322" rpy="0 0 0"/>
        <axis xyz="-1.0 -0.0 0.0"/>
        <limit lower="-1.5708" upper="1.5708" effort="150.0" velocity="1.0"/>
    </joint>

    <joint name="joint_3" type="revolute">
        <parent link="link_2"/>
        <child link="link_3"/>
        <origin xyz="0.0 0.225 0.0" rpy="0 0 0"/>
        <axis xyz="1.0 0.0 -0.0"/>
        <limit lower="-2.0944" upper="2.0944" effort="100.0" velocity="1.0"/>
    </joint>

    <joint name="joint_4" type="revolute">
        <parent link="link_3"/>
        <child link="link_4"/>
        <origin xyz="0.08 0.225 0.0" rpy="0 0 0"/>
        <axis xyz="-1.0 -0.0 0.0"/>
        <limit lower="-2.0944" upper="2.0944" effort="50.0" velocity="1.5"/>
    </joint>

    <joint name="joint_5" type="revolute">
        <parent link="link_4"/>
        <child link="link_5"/>
        <origin xyz="-0.028 0.021812 -4e-06" rpy="0 0 0"/>
        <axis xyz="-0.0 1.0 -0.0"/>
        <limit lower="-3.14159" upper="3.14159" effort="30.0" velocity="2.0"/>
    </joint>

    <joint name="link5_to_midpoint" type="fixed">
        <parent link="link_5"/>
        <child link="gripper_mid_point"/>
        <origin xyz="0 0.075 0" rpy="0 0 0"/>
    </joint>

    <joint name="gripperbase_to_armgearright" type="revolute">
        <parent link="link_5"/>
        <child link="gripper_finger_right"/>
        <origin xyz="0.009742 0.081458 0.0" rpy="0 0 0"/>
        <axis xyz="-0.0 0.0 1.0"/>
        <limit lower="-0.75" upper="0.5" effort="1.5" velocity="2.0"/>
    </joint>

    <joint name="gripperbase_to_armgearleft" type="revolute">
        <parent link="link_5"/>
        <child link="gripper_finger_left"/>
        <origin xyz="-0.009743 0.081458 0.0" rpy="0 0 0"/>
        <axis xyz="-0.0 0.0 1.0"/>
        <limit lower="-0.75" upper="0.5" effort="1.5" velocity="2.0"/>
        <mimic joint="gripperbase_to_armgearright" multiplier="-1"/>
    </joint>

</robot>