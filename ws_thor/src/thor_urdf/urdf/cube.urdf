<?xml version="1.0"?>
<robot name="cube">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.00013" ixy="0" ixz="0" iyy="0.00013" iyz="0" izz="0.00013"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>100.0</mu>
            <mu2>100.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>100.0</mu1>
    <mu2>100.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0.0</maxVel>
    <maxContacts>2</maxContacts>
  </gazebo>
</robot>
